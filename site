                        <div style="font-size:0.8rem;color:#94a3b8;margin-bottom:6px;">${{label}}</div>
                        <div style="font-size:1.25rem;font-weight:700;color:#f8fafc;">${{value}}</div>
                    </div>
                `;
            }}

            function renderMetrics() {{
                if (!config.showMetrics) return;
                const values = machineNames.map((name) => displayValues[name] || 0);
                const avg = values.length ? values.reduce((sum, value) => sum + value, 0) / values.length : 0;
                const peak = values.length ? Math.max(...values) : 0;
                const min = values.length ? Math.min(...values) : 0;
                const metricsEl = document.getElementById('rt-metrics');
                const cards = [
                    buildMetricCard('Avg Load', `${{avg.toFixed(2)}} A`),
                    buildMetricCard('Peak Load', `${{peak.toFixed(2)}} A`),
                    buildMetricCard('Min Load', `${{min.toFixed(2)}} A`),
                ];
                if (lastVoltage !== null && Number.isFinite(lastVoltage)) cards.push(buildMetricCard('Voltage', `${{lastVoltage.toFixed(2)}} V`));
                metricsEl.innerHTML = cards.join('');
            }}

            function renderGauges() {{
                const perRow = Math.min(machineNames.length || 1, 5);
                const rows = Math.ceil((machineNames.length || 1) / perRow);
                const gapX = perRow <= 2 ? 0.05 : 0.03;
                const gapY = 0.05;
                const data = machineNames.map((name, index) => {{
                    const col = index % perRow;
                    const row = Math.floor(index / perRow);
                    const x0 = col / perRow + gapX;
                    const x1 = (col + 1) / perRow - gapX;
                    const y0 = ((rows - 1 - row) / rows) + gapY;
                    const y1 = ((rows - row) / rows) - gapY;
                    return {{
                        type: 'indicator',
                        mode: 'gauge+number',
                        value: displayValues[name] || 0,
                        title: {{ text: name, font: {{ size: 13, color: '#f1f5f9' }} }},
                        number: {{ suffix: ' A', font: {{ size: 22, color: colors[index % colors.length], family: 'monospace' }} }},
                        gauge: {{ axis: {{ range: [0, 8] }}, bar: {{ color: colors[index % colors.length], thickness: 0.28 }}, bgcolor: '#1e293b', borderwidth: 0 }},
                        domain: {{ x: [x0, x1], y: [y0, y1] }},
                    }};
                }});
                Plotly.react('rt-gauges', data, {{
                    paper_bgcolor: '#0f172a',
                    plot_bgcolor: '#0f172a',
                    font: {{ color: '#f1f5f9' }},
                    margin: {{ l: 10, r: 10, t: 10, b: 10 }},
                    height: 230 * rows,
                }}, {{ displayModeBar: false, responsive: true }});
            }}

            function renderTrend() {{
                if (!historyTimes.length) {{
                    historyTimes.push(formatClockTime(new Date().toISOString()));
                }}
                machineNames.forEach((name) => {{
                    if (!historySeries[name].length) {{
                        historySeries[name].push(displayValues[name] || targetValues[name] || 0.5);
                    }}
                }});
                const root = document.getElementById('rt-trend');
                const width = Math.max(280, (root.clientWidth || 0) - 16);
                const isCompact = width < 520;
                const height = config.showMetrics ? (isCompact ? 340 : 420) : (isCompact ? 280 : 340);
                const padding = config.showMetrics
                    ? {{ top: 18, right: isCompact ? 10 : 20, bottom: isCompact ? 80 : 68, left: isCompact ? 42 : 58 }}
                    : {{ top: 18, right: isCompact ? 10 : 20, bottom: isCompact ? 64 : 52, left: isCompact ? 42 : 58 }};
                const innerWidth = width - padding.left - padding.right;
                const innerHeight = height - padding.top - padding.bottom;
                const maxY = 8;
                const minY = 0;
                const pointCount = Math.max(2, historyTimes.length);
                const xStep = pointCount > 1 ? innerWidth / (pointCount - 1) : innerWidth;
                const yTicks = [0, 2, 4, 6, 8];
                const tickStart = Math.max(0, historyTimes.length - (isCompact ? 4 : 6));
                const xLabels = historyTimes.slice(tickStart).map((label) => formatClockTime(label));
                const latestLabel = formatClockTime(historyTimes[historyTimes.length - 1]);
                const latestTickIndex = historyTimes.length - 1;
                const maxTickLabels = isCompact ? 3 : 5;
                const visibleLabelIndices = new Set();
                if (xLabels.length <= maxTickLabels) {{
                    for (let i = 0; i < xLabels.length; i += 1) visibleLabelIndices.add(i);
                }} else {{
                    for (let i = 0; i < maxTickLabels; i += 1) {{
                        const pos = Math.round((i * (xLabels.length - 1)) / (maxTickLabels - 1));
                        visibleLabelIndices.add(pos);
                    }}
                }}

                const toX = (index) => padding.left + (index * xStep);
                const toY = (value) => padding.top + innerHeight - (((value - minY) / (maxY - minY)) * innerHeight);

                const gridLines = yTicks.map((tick) => {{
                    const y = toY(tick);
                    return `
                        <line x1="${{padding.left}}" y1="${{y}}" x2="${{width - padding.right}}" y2="${{y}}" stroke="#1e293b" stroke-width="1" />
                        <text x="${{padding.left - 8}}" y="${{y + 4}}" fill="#94a3b8" font-size="11" text-anchor="end">${{tick}}</text>
                    `;
                }}).join('');

                const xTickLabels = xLabels.map((label, labelIndex) => {{
                    if (!visibleLabelIndices.has(labelIndex)) return '';
                    const absoluteIndex = tickStart + labelIndex;
                    const x = toX(absoluteIndex);
                    const isLatestTick = absoluteIndex === latestTickIndex;
                    const tickY = height - 10;
                    const transform = isCompact ? `rotate(-20 ${{x}} ${{tickY}})` : '';
                    const labelColor = isLatestTick ? '#f8fafc' : '#94a3b8';
                    const labelWeight = isLatestTick ? '700' : '400';
                    return `
                        <text x="${{x}}" y="${{tickY}}" fill="${{labelColor}}" font-size="10" font-weight="${{labelWeight}}" text-anchor="middle" transform="${{transform}}">${{label}}</text>
                        ${{isLatestTick ? `<circle cx="${{x}}" cy="${{height - padding.bottom}}" r="3.5" fill="#f8fafc"></circle>` : ''}}
                    `;
                }}).join('');

                const areas = machineNames.map((name, index) => {{
                    const series = historySeries[name] || [];
                    if (!series.length) return '';
                    const linePoints = series.map((value, pointIndex) => `${{toX(pointIndex)}},${{toY(value)}}`).join(' ');
                    const areaPoints = [
                        `${{toX(0)}},${{toY(0)}}`,
                        ...series.map((value, pointIndex) => `${{toX(pointIndex)}},${{toY(value)}}`),
                        `${{toX(series.length - 1)}},${{toY(0)}}`,
                    ].join(' ');
                    const hex = colors[index % colors.length];
                    const r = parseInt(hex.slice(1, 3), 16);
                    const g = parseInt(hex.slice(3, 5), 16);
                    const b = parseInt(hex.slice(5, 7), 16);
                    const hoverDots = series.map((value, pointIndex) => {{
                        const x = toX(pointIndex);
                        const y = toY(value);
                        const ts = formatClockTime(historyTimes[pointIndex] || '');
                        return `
                            <circle cx="${{x}}" cy="${{y}}" r="8" fill="rgba(0,0,0,0.001)">
                                <title>${{name}} | ${{ts}} | ${{value.toFixed(2)}} A</title>
                            </circle>
                        `;
                    }}).join('');
                    return `
                        <polygon points="${{areaPoints}}" fill="rgba(${{r}}, ${{g}}, ${{b}}, 0.10)"></polygon>
                        <polyline points="${{linePoints}}" fill="none" stroke="${{hex}}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></polyline>
                        ${{hoverDots}}
                    `;
                }}).join('');

                const legend = machineNames.map((name, index) => `
                    <div style="display:flex; align-items:center; gap:6px; margin-right:14px; font-size:12px; color:#cbd5e1;">
                        <span style="display:inline-block; width:10px; height:10px; border-radius:999px; background:${{colors[index % colors.length]}};"></span>
                        <span>${{name}}</span>
                    </div>
                `).join('');

                root.innerHTML = `
                    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px; padding:6px 8px 2px 8px;">
                        <div style="display:flex; align-items:center; gap:8px; font-size:12px; color:#94a3b8;">
                            <span>Laatst gemeten:</span>
                            <span style="display:inline-flex; align-items:center; padding:4px 10px; border-radius:999px; background:#1e293b; border:1px solid #334155; color:#f8fafc; font-weight:700; letter-spacing:0.02em;">${{latestLabel}}</span>
                        </div>
                        <div style="display:flex; justify-content:flex-end; flex-wrap:wrap; gap:4px;">${{legend}}</div>
                    </div>
                    <svg viewBox="0 0 ${{width}} ${{height}}" width="100%" height="${{height}}" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Live current trend chart" style="display:block; max-width:100%; overflow:hidden;">
                        <rect x="0" y="0" width="${{width}}" height="${{height}}" fill="#0f172a"></rect>
                        ${{gridLines}}
                        <line x1="${{padding.left}}" y1="${{padding.top}}" x2="${{padding.left}}" y2="${{height - padding.bottom}}" stroke="#475569" stroke-width="1.5"></line>
                        <line x1="${{padding.left}}" y1="${{height - padding.bottom}}" x2="${{width - padding.right}}" y2="${{height - padding.bottom}}" stroke="#475569" stroke-width="1.5"></line>
                        ${{areas}}
                        ${{xTickLabels}}
                        <text x="${{width / 2}}" y="${{height - 18}}" fill="#cbd5e1" font-size="12" text-anchor="middle">Tijd</text>
                        <text x="18" y="${{height / 2}}" fill="#cbd5e1" font-size="12" text-anchor="middle" transform="rotate(-90 18 ${{height / 2}})">Stroom (A)</text>
                    </svg>
                `;
            }}

            window.addEventListener('resize', () => {{
                renderTrend();
                renderGauges();
            }});

            function pushHistory() {{
                const now = formatClockTime(new Date().toISOString());
                historyTimes.push(now);
                if (historyTimes.length > maxPoints) historyTimes.shift();
                machineNames.forEach((name) => {{
                    historySeries[name].push(displayValues[name] || targetValues[name] || 0.5);
                    if (historySeries[name].length > maxPoints) historySeries[name].shift();
                }});
            }}

            function nextSimulationValue(name, index) {{
                const base = targetValues[name] || (1.2 + index * 0.35);
                const delta = (Math.random() - 0.5) * 0.6;
                return clamp(base + delta, 0.5, 6.0);
            }}

            async function pollTargets() {{
                if (config.mode === 'Simulation' || !endpoints.length) {{
                    machineNames.forEach((name, index) => {{
                        targetValues[name] = nextSimulationValue(name, index);
                    }});
                    lastVoltage = null;
                    return;
                }}

                const responses = await Promise.all(endpoints.map(async (endpoint) => {{
                    try {{
                        const response = await fetch(endpoint, {{ cache: 'no-store' }});
                        if (!response.ok) throw new Error(`HTTP ${{response.status}}`);
                        return await response.json();
                    }} catch (error) {{
                        return null;
                    }}
                }}));

                machineNames.forEach((name, index) => {{
                    const payload = responses[index];
                    if (payload) {{
                        targetValues[name] = extractCurrent(payload);
                        if (typeof payload.voltage === 'number') lastVoltage = payload.voltage;
                    }}
                }});
            }}

            function animateStep() {{
                machineNames.forEach((name) => {{
                    const current = displayValues[name] || 0;
                    const target = targetValues[name] || 0;
                    const delta = target - current;
                    const maxStep = 0.45;
                    const eased = delta * 0.35;
                    const step = Math.abs(eased) > maxStep ? Math.sign(eased) * maxStep : eased;
                    displayValues[name] = Math.abs(delta) < 0.01 ? target : current + step;
                }});
                renderMetrics();
                renderGauges();
            }}

            async function pollAndRender() {{
                await pollTargets();
                pushHistory();
                renderMetrics();
                renderGauges();
                renderTrend();
            }}

            renderMetrics();
            renderGauges();
            renderTrend();
            pollAndRender();
            window.setInterval(pollAndRender, config.refreshMs);
            window.setInterval(animateStep, config.animationMs);
        </script>
        """


def render_client_realtime_panel(machine_names, panel_title, show_metrics=True):
    """Render a client-side realtime panel that updates without Streamlit reruns."""
    connected_devices = st.session_state.get("connected_devices", [])
    current_df = st.session_state.get("df", pd.DataFrame())
    endpoint_by_name = {}
    for index, device in enumerate(connected_devices):
        device_name = device.get("name") or (
            st.session_state.machine_names[index]
            if index < len(st.session_state.machine_names)
            else f"ESP32 {index + 1}"
        )
        endpoint_by_name[device_name] = device.get("endpoint") or build_device_endpoint(
            device.get("ip"),
            device.get("port", 80),
        )

    endpoints = []
    for machine_name in machine_names:
        endpoint = endpoint_by_name.get(machine_name)
        if endpoint:
            endpoints.append(endpoint)

    initial_history = {"times": [], "series": {name: [] for name in machine_names}}
    if isinstance(current_df, pd.DataFrame) and not current_df.empty:
        if "timestamp" in current_df.columns:
            initial_history["times"] = [
                pd.to_datetime(timestamp).strftime("%H:%M:%S")
                for timestamp in current_df["timestamp"].tail(100).tolist()
            ]
        else:
            initial_history["times"] = [str(index + 1) for index in range(len(current_df.tail(100)))]

        for machine_name in machine_names:
            machine_index = next(
                (index + 1 for index, name in enumerate(st.session_state.machine_names) if name == machine_name),
                None,
            )
            if machine_index is None:
                continue
            column_name = f"current_{machine_index}"
            if column_name in current_df.columns:
                initial_history["series"][machine_name] = [
                    float(value) for value in current_df[column_name].tail(100).tolist()
                ]

    html = build_client_realtime_component_html(
        machine_names=machine_names,
        endpoints=endpoints,
        mode=st.session_state.get("mode", "Simulation"),
        refresh_seconds=max(1, int(st.session_state.get("refresh_rate", 2))),
        panel_title=panel_title,
        show_metrics=show_metrics,
        initial_history=initial_history,
    )
    rows = max(1, (len(machine_names) + min(len(machine_names), 5) - 1) // max(1, min(len(machine_names), 5)))
    base_height = 980 if show_metrics else 780
    components.html(html, height=base_height + (rows - 1) * 190, scrolling=False)

